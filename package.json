{
  "name": "bunq",
  "version": "0.1.0",
  "description": "High-performance job queue server for Bun. SQLite persistence, cron jobs, priorities, DLQ.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "build": "bun build --compile --minify src/main.ts --outfile dist/bunq",
    "build:lib": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "bench": "bun run benchmarks/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "prepublishOnly": "bun run build:lib"
  },
  "dependencies": {
    "croner": "^9.0.0",
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3",
    "@eslint/js": "^9.18.0",
    "typescript-eslint": "^8.21.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "job-queue",
    "task-queue",
    "background-jobs",
    "bun",
    "sqlite",
    "cron",
    "worker",
    "queue"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/egeominotti/bunq"
  }
}
